# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (Supabase Postgres) ──────────────────────────
# Dùng connection string dạng 5432; code tự đổi sang pooler 6543 + pgbouncer.
# Lấy ở: Supabase project → Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres

# ── Auth (JWT) ────────────────────────────────────────────
JWT_SECRET=doi-thanh-chuoi-bi-mat-that-dai-ngau-nhien
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# ── AI (Gemini — chấm câu tự do + voice chat) ─────────────
# Lấy key MIỄN PHÍ ở https://aistudio.google.com (chỉ cần tài khoản Google).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── TTS (tạo giọng đọc — điền sau khi làm TN1) ────────────
# OPENAI_API_KEY=

# ── Pronunciation (Azure — điền sau khi làm TN2) ──────────
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
